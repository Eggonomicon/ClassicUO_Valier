<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net472</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>Preview</LangVersion>
    <AssemblyName>ValierClassicUO</AssemblyName>
    <RootNamespace>ClassicUO</RootNamespace>
    <ApplicationIcon>ValierIcon.ico</ApplicationIcon>
    <PlatformTarget>x64</PlatformTarget>
    <Product>Valier ClassicUO Client</Product>
    <Company>ValierUO</Company>
    <Description>Valier ClassicUO Client</Description>
    <FileVersion>1.0.0.0</FileVersion>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="cuoicon.ico" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Buffers" Version="4.5.1" />
    <PackageReference Include="System.Memory" Version="4.5.5" />
    <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="6.0.0" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="cuoapi">
      <HintPath>..\..\..\external\cuoapi\cuoapi.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>